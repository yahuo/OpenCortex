# OpenCortex 环境变量示例
# 复制为 .env 后按需修改

# 本地文本目录（会递归索引）
LOCAL_DOCS_DIR=./docs

# Embedding
EMBED_API_KEY=sf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3
# 大语料重建默认使用更大的 batch，并且只在触发限流时退避。
# 如需更保守的 provider 配置，可显式调小批次或恢复固定 sleep。
# `EMBED_BATCH_SLEEP_SECONDS` 仅在 `EMBED_CONCURRENCY=1` 时生效。
# EMBED_BATCH_SIZE=64
# EMBED_CONCURRENCY=1
# EMBED_BATCH_SLEEP_SECONDS=0

# 后处理阶段控制：
# - `SEMANTIC_GRAPH_ENABLED` 默认关闭，构建期不再调用 LLM 抽取语义实体。
#   实体图（entity_graph）只保留 file/section/symbol 这些纯结构节点；
#   检索缺失实体边时会自动回退到 document_graph。
#   想恢复 LLM 语义抽取（生成 concept/decision 节点 + semantically_related 边），
#   显式设 `SEMANTIC_GRAPH_ENABLED=1`，并确保 LLM_API_KEY/MODEL/BASE_URL 配齐。
# SEMANTIC_GRAPH_ENABLED=1
#
# 超大语料首轮建索引时，可再跳过文档图与 wiki 加快构建。
# 对 10GB 级语料，首轮构建强烈建议先开 `SKIP_GRAPH=1`。
# SKIP_GRAPH=1
# SKIP_WIKI=1

# LLM
LLM_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.0-flash

# FAISS 索引目录
CHROMA_PERSIST_DIR=~/wechat_rag_db

# 检索模式：vector / hybrid / agentic
SEARCH_MODE=hybrid

# 最终进入上下文的证据块数量上限。
# Rerank 即使先看更多候选，最后保留给答案模型的仍是这里的数量。
# SEARCH_TOP_K=6

# agentic 模式最多允许 1 次二跳检索，仅支持 1 或 2
SEARCH_MAX_STEPS=2

# Rerank：RRF 融合后用 LLM 对 top-N 候选重打分。默认开；
# 缺 LLM_API_KEY/BASE_URL 会自动降级为不 rerank 不报错（trace 写 no_credentials）。
# RERANK_MODEL 可单独指定一个更便宜/更快的模型；留空则复用 LLM_MODEL。
# RERANK_ENABLED=1
# RERANK_TOP_N=30
# RERANK_MODEL=

# 分片参数
# 微信导出这类超大聊天 Markdown 可适当增大 CHUNK_SIZE，并配合 MAX_CHUNKS_PER_FILE 防失控。
# CHUNK_SIZE=1200
# CHUNK_OVERLAP_LINES=3
# 单文件最多保留多少个 chunk；0 或留空表示不截断。
# 注意：超出部分会被丢弃，微信聊天会优先保留最新片段；manifest 会记录 original_chunks / truncated。
# MAX_CHUNKS_PER_FILE=0

# 微信聊天 chunk 合并阈值：
# 30 分钟时间窗切完后，相邻小窗口会被合并到一起，避免 1000+ chunk 的活跃群被切成
# 大量微 chunk。合并条件：(prev<MIN 或 cur<MIN) 且合并后 <=MAX 且两窗口间隔 <=GAP 分钟。
# 调小 MIN / 调大 MAX 都会增加合并力度；调小 GAP 会避免跨主题粘连。
# WECHAT_MIN_CHUNK_CHARS=800
# WECHAT_MAX_CHUNK_CHARS=3000
# WECHAT_QUIET_GAP_MINUTES=120

# 额外忽略目录 / 文件模式，逗号分隔
# EXCLUDE_GLOBS=.cache/*,tmp/*

# Streamlit 调试：展示检索轨迹
# SEARCH_DEBUG=false

# 可选：启动地址（start.py 使用）
# Docker 部署时，容器内监听地址和端口固定为 0.0.0.0:8501 / 8502；
# 上面的 APP_PORT / API_PORT 仅用于 docker-compose 暴露到宿主机的端口。
APP_HOST=127.0.0.1
APP_PORT=8501
API_PORT=8502

# ── Docker 部署说明 ─────────────────────────────────────────────────────
# docker-compose.yml 使用上面的 LOCAL_DOCS_DIR 和 CHROMA_PERSIST_DIR 作为
# 宿主机挂载路径（volume source），容器内固定使用 /data/docs 和 /data/index。
# 请将两个路径设为宿主机上的绝对路径或相对于 docker-compose.yml 的路径。
#
# 首次部署流程：
#   docker compose build
#   docker compose run --rm app python start.py --rebuild-only
#   docker compose up -d
#
# 文档更新后热加载（无需重启容器）：
#   docker compose exec app python start.py --rebuild-only
