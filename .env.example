# OpenCortex 环境变量示例
# 复制为 .env 后按需修改

# 本地文本目录（会递归索引）
LOCAL_DOCS_DIR=./docs

# Embedding
EMBED_API_KEY=sf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3
# 大语料重建默认使用更大的 batch，并且只在触发限流时退避。
# 如需更保守的 provider 配置，可显式调小批次或恢复固定 sleep。
# `EMBED_BATCH_SLEEP_SECONDS` 仅在 `EMBED_CONCURRENCY=1` 时生效。
# EMBED_BATCH_SIZE=64
# EMBED_CONCURRENCY=1
# EMBED_BATCH_SLEEP_SECONDS=0

# 超大语料首轮建索引时，可先只产出向量库，跳过较慢的后处理。
# 对 10GB 级语料，首轮构建强烈建议先开 `SKIP_GRAPH=1`。
# SKIP_GRAPH=1
# SKIP_SEMANTIC=1
# SKIP_WIKI=1

# LLM
LLM_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.0-flash

# FAISS 索引目录
CHROMA_PERSIST_DIR=~/wechat_rag_db

# 检索模式：vector / hybrid / agentic
SEARCH_MODE=hybrid

# agentic 模式最多允许 1 次二跳检索，仅支持 1 或 2
SEARCH_MAX_STEPS=2

# 额外忽略目录 / 文件模式，逗号分隔
# EXCLUDE_GLOBS=.cache/*,tmp/*

# Streamlit 调试：展示检索轨迹
# SEARCH_DEBUG=false

# 可选：启动地址（start.py 使用）
# Docker 部署时，容器内监听地址和端口固定为 0.0.0.0:8501 / 8502；
# 上面的 APP_PORT / API_PORT 仅用于 docker-compose 暴露到宿主机的端口。
APP_HOST=127.0.0.1
APP_PORT=8501
API_PORT=8502

# ── Docker 部署说明 ─────────────────────────────────────────────────────
# docker-compose.yml 使用上面的 LOCAL_DOCS_DIR 和 CHROMA_PERSIST_DIR 作为
# 宿主机挂载路径（volume source），容器内固定使用 /data/docs 和 /data/index。
# 请将两个路径设为宿主机上的绝对路径或相对于 docker-compose.yml 的路径。
#
# 首次部署流程：
#   docker compose build
#   docker compose run --rm app python start.py --rebuild-only
#   docker compose up -d
#
# 文档更新后热加载（无需重启容器）：
#   docker compose exec app python start.py --rebuild-only
