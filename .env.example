# ─────────────────────────────────────────────────────────
# WechatLLM 环境变量配置文件
# 复制本文件为 .env 并填入你自己的 API Key
# ─────────────────────────────────────────────────────────

# ══════════════════════════════════════════
# 🔓 解密数据库（可选，若不设置则使用代码默认值）
# ══════════════════════════════════════════
# WECHATLLM_DB_DIR=/Users/你的用户名/wechat_db_backup
# WECHATLLM_OUT_DIR=/Users/你的用户名/wechat_export

# ══════════════════════════════════════════
# 🧩 Embedding 模型（向量化，用于构建索引）
# ══════════════════════════════════════════

# 硅基流动（默认）
EMBED_API_KEY=sf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3

# 如果换成 OpenAI 官方 Embedding：
# EMBED_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_MODEL=text-embedding-3-small

# ══════════════════════════════════════════
# 🤖 LLM 模型（生成回答）
# ══════════════════════════════════════════

# Gemini（默认）
LLM_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.0-flash

# Kimi（切换时取消注释以下三行，注释掉上方三行）
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-32k

# GLM（智谱）
# LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-4-flash

# DeepSeek
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ══════════════════════════════════════════
# 📦 ChromaDB 持久化目录
# ══════════════════════════════════════════
CHROMA_PERSIST_DIR=~/wechat_rag_db
